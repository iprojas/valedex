---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ModelViewer from "../../components/ModelViewer.astro";

export async function getStaticPaths() {
  const entries = await getCollection("valemones");
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<BaseLayout
  title={`${entry.data.name} RA | Valedex`}
  description={`Experiencia de realidad aumentada de ${entry.data.name}.`}
  bodyClass="ar-body"
>
  <main class="ar-screen" aria-label={`Experiencia de realidad aumentada de ${entry.data.name}`} data-ar-page data-slug={entry.data.slug}>
    <ModelViewer model={entry.data.model} image={entry.data.image} environment={entry.data.environment} name={entry.data.name} ar />
  </main>

  <script>
    import { isCaptured } from "../../scripts/collection-state";

    function guardArPage() {
      const page = document.querySelector<HTMLElement>("[data-ar-page]");
      const slug = page?.dataset.slug || "";

      if (slug && !isCaptured(slug)) {
        window.location.href = "/";
      }
    }

    document.addEventListener("astro:page-load", guardArPage);
    document.addEventListener("DOMContentLoaded", guardArPage);
  </script>
</BaseLayout>
