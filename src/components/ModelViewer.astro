---
interface Props {
  model: string;
  name: string;
  ar?: boolean;
}

const { model, name, ar = false } = Astro.props;
---

{
  ar ? (
    <model-viewer
      id="model-viewer"
      src={model}
      alt={`Modelo 3D de ${name}`}
      camera-controls
      touch-action="pan-y"
      shadow-intensity="2"
      environment-image="neutral"
      ar
      ar-modes="scene-viewer quick-look"
    >
      <button slot="ar-button" class="ar-launch nes-btn is-primary">Ver en AR</button>
      <div id="error" class="hide">AR no está disponible en este dispositivo</div>
    </model-viewer>
  ) : (
    <model-viewer
      id="model-viewer"
      src={model}
      alt={`Modelo 3D de ${name}`}
      camera-controls
      touch-action="pan-y"
      shadow-intensity="2"
      environment-image="neutral"
      auto-rotate
      disable-pan
      skybox-height="2m"
      max-camera-orbit="auto 90deg auto"
    >
      <div id="error" class="hide">No se pudo cargar el modelo 3D.</div>
    </model-viewer>
  )
}

<script type="module" src="https://cdn.jsdelivr.net/npm/@google/model-viewer/dist/model-viewer.min.js"></script>
