---
interface Props {
  model: string | null;
  image: string;
  environment: string;
  name: string;
  ar?: boolean;
  enableAr?: boolean;
}

const { model, image, environment, name, ar = false, enableAr = false } = Astro.props;
---

{
  !model ? (
    <figure class="model-fallback" aria-label={`Imagen de ${name}`}>
      <img src={image} alt={name} />
      {ar && <figcaption>Modelo de realidad aumentada no disponible</figcaption>}
    </figure>
  ) : ar ? (
    <model-viewer
      id="model-viewer"
      src={model}
      alt={`Modelo 3D de ${name}`}
      camera-controls
      touch-action="pan-y"
      shadow-intensity="2"
      environment-image={environment}
      skybox-image={environment}
      ar
      ar-modes="scene-viewer quick-look"
    >
      <button slot="ar-button" class="ar-launch icon-button" aria-label="Ver en realidad aumentada">
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M2.5 12s3.5-6 9.5-6 9.5 6 9.5 6-3.5 6-9.5 6-9.5-6-9.5-6Z" />
          <circle cx="12" cy="12" r="3" />
          <path d="M18.5 3.5v3M17 5h3" />
        </svg>
      </button>
      <div id="error" class="hide">La realidad aumentada no está disponible en este dispositivo.</div>
    </model-viewer>
  ) : enableAr ? (
    <model-viewer
      id="model-viewer"
      src={model}
      alt={`Modelo 3D de ${name}`}
      camera-controls
      touch-action="pan-y"
      shadow-intensity="2"
      environment-image={environment}
      skybox-image={environment}
      ar
      ar-modes="scene-viewer quick-look"
      auto-rotate
      disable-pan
      skybox-height="2m"
      max-camera-orbit="auto 90deg auto"
    >
      <div id="error" class="hide">La realidad aumentada no está disponible en este dispositivo.</div>
    </model-viewer>
  ) : (
    <model-viewer
      id="model-viewer"
      src={model}
      alt={`Modelo 3D de ${name}`}
      camera-controls
      touch-action="pan-y"
      shadow-intensity="2"
      environment-image={environment}
      skybox-image={environment}
      auto-rotate
      disable-pan
      skybox-height="2m"
      max-camera-orbit="auto 90deg auto"
    >
      <div id="error" class="hide">No se pudo cargar el modelo 3D.</div>
    </model-viewer>
  )
}

<script type="module" src="https://cdn.jsdelivr.net/npm/@google/model-viewer/dist/model-viewer.min.js"></script>
